{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title", "level"],
  "properties": {
    "title": { "type": "string" },
    "body":  { "type": "string" },
    "level": { "type": "string", "enum": ["info", "warning", "error"] },
    "url":   { "type": "string" }
  }
}
